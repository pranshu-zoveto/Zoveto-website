# =============================================================================
# Zoveto marketing site — environment template (COMMIT-SAFE)
# =============================================================================
# Copy to `.env.local` for local dev. Never commit `.env`, `.env.local`, or secrets.
#
# Browser / build-time (`NEXT_PUBLIC_*` are inlined at `next build` on Vercel)
# =============================================================================

# Canonical public origin (no trailing slash). Production: https://zoveto.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# COS REST API base URL including `/api` (legacy direct browser calls if any)
NEXT_PUBLIC_COS_API_URL=http://127.0.0.1:4000/api

# Product app URL (redirects for /app, /login)
NEXT_PUBLIC_COS_APP_URL=http://localhost:5173

# Optional: GA4 (loads only after cookie consent)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Google Search Console HTML tag token
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Microsoft Clarity (after analytics consent)
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Optional: Google Sign-In on marketing pages
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Server-only (Route Handlers — never exposed to the browser)
# =============================================================================

# COS base URL including `/api` for server-side proxy (Docker: http://api:3000/api)
COS_API_BASE_URL=http://127.0.0.1:4000/api

# Optional: shared secret — must match COS `WEB_CONTACT_SECRET` when COS enforces it
# WEB_CONTACT_SECRET=

# -----------------------------------------------------------------------------
# Optional: SMTP for `lib/server-mail.ts` (signup/contact/demo inward notifications).
# Omit entirely if you rely on COS-only email — routes degrade gracefully when unset.
# -----------------------------------------------------------------------------
# MAIL_FROM=Zoveto <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# =============================================================================
# Vercel / production hardening (set in dashboard, not usually in `.env.local`)
# =============================================================================

# Automatic on Vercel — enables Strict-Transport-Security header path in next.config.mjs
# VERCEL=1

# Optional HSTS: add preload directive (submit domain to HSTS preload list only after validation)
# HSTS_PRELOAD=1

# Set to "0" to omit includeSubDomains (rare — only if you host non-TLS HTTP subdomains)
# HSTS_INCLUDE_SUBDOMAINS=0

# Emergency: disable HSTS header for debugging broken TLS only
# DISABLE_HSTS=1

# Rate limit bypass — load testing / local only (never enable in production)
# API_RATE_LIMIT_DISABLED=1
# DISABLE_API_RATE_LIMIT=1
