# =============================================================================
# Zoveto marketing site — environment template (COMMIT-SAFE)
# =============================================================================
# Copy to `.env.local` for local dev. Never commit `.env`, `.env.local`, or secrets.
#
# Browser / build-time (`NEXT_PUBLIC_*` are inlined at `next build` on Vercel)
# =============================================================================

# Canonical public origin (no trailing slash). Production: https://zoveto.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# COS REST API base URL including `/api` (legacy direct browser calls if any)
NEXT_PUBLIC_COS_API_URL=http://127.0.0.1:4000/api

# Product app URL (redirects for /app, /login)
NEXT_PUBLIC_COS_APP_URL=http://localhost:5173

# GA4 — Google tag (gtag.js); one loader in app (after analytics consent). Set on Vercel for production.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-TJP3DXS9MG

# Optional: Google Search Console HTML tag token
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Microsoft Clarity — project ID only from Clarity → Setup (not the full script). Loads after analytics consent.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Optional: PostHog (analytics + session replay). Loads after analytics consent. Project settings → Project API key + API host (US/EU).
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: Google Sign-In on marketing pages
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Sentry (@sentry/nextjs) — error monitoring (browser + Node API routes + Edge)
# Create project: https://sentry.io — Client Keys → DSN (same value for client + server).
# Vercel: set NEXT_PUBLIC_SENTRY_DSN + SENTRY_DSN to the same DSN string.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.de.sentry.io/xxxx
# SENTRY_DSN=https://xxxx@xxxx.ingest.de.sentry.io/xxxx

# Optional: split Preview vs Production in Sentry (otherwise NODE_ENV is used on the client).
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=preview

# Optional server-side override (else VERCEL_ENV / NODE_ENV).
# SENTRY_ENVIRONMENT=production

# Source maps upload (CI / Vercel build — never expose SENTRY_AUTH_TOKEN to the browser).
# org/project slugs appear in Sentry → Settings → Projects.
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=zoveto-website

# One-shot verification (unset after testing):
# NEXT_PUBLIC_SENTRY_VERIFICATION=1   # build-time: client throws "Sentry Frontend Test Error" once — redeploy without it after
# SENTRY_VERIFY_SECRET=long-random    # POST /api/v1/sentry-verify with JSON {"secret":"..."} — remove after Issues show the event

# -----------------------------------------------------------------------------
# Uptime / synthetic monitors (UptimeRobot, Better Stack, Pingdom, etc.)
# This app does NOT require monitor-specific env vars. Point your monitor at:
#   GET https://<your-domain>/api/v1/health
# JSON: { "status":"ok", "service":"zoveto-website", "ts":"..." } — Cache-Control: no-store
# Use HTTPS, 2–5 min interval, alert on non-200 or missing JSON. Optional: same URL for "Keyword" monitors checking "ok".
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Vercel Speed Insights & Web Analytics (dashboard toggles — usually no env here)
# Enable in Vercel → Project → Speed Insights / Analytics. This repo loads them via
# `components/layout/VercelWebMetrics.tsx` when deployed on Vercel (no DSN in .env for those products).
# -----------------------------------------------------------------------------

# =============================================================================
# Server-only (Route Handlers — never exposed to the browser)
# =============================================================================

# COS base URL including `/api` for server-side proxy (Docker: http://api:3000/api)
COS_API_BASE_URL=http://127.0.0.1:4000/api

# Optional: shared secret — must match COS `WEB_CONTACT_SECRET` when COS enforces it
# WEB_CONTACT_SECRET=

# -----------------------------------------------------------------------------
# Optional: SMTP for `lib/server-mail.ts` (signup/contact/demo inward notifications).
# Omit entirely if you rely on COS-only email — routes degrade gracefully when unset.
# -----------------------------------------------------------------------------
# MAIL_FROM=Zoveto <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# =============================================================================
# Vercel / production hardening (set in dashboard, not usually in `.env.local`)
# =============================================================================

# Automatic on Vercel — enables Strict-Transport-Security header path in next.config.mjs
# VERCEL=1

# Optional HSTS: add preload directive (submit domain to HSTS preload list only after validation)
# HSTS_PRELOAD=1

# Set to "0" to omit includeSubDomains (rare — only if you host non-TLS HTTP subdomains)
# HSTS_INCLUDE_SUBDOMAINS=0

# Emergency: disable HSTS header for debugging broken TLS only
# DISABLE_HSTS=1

# Rate limit bypass — load testing / local only (never enable in production)
# API_RATE_LIMIT_DISABLED=1
# DISABLE_API_RATE_LIMIT=1

# =============================================================================
# Vercel Production — quick checklist (set in dashboard; redeploy after changes)
# =============================================================================
# Required for correct canonical URLs + sitemap:
#   NEXT_PUBLIC_SITE_URL=https://zoveto.com
# Recommended for app links + redirects in next.config.mjs:
#   NEXT_PUBLIC_COS_APP_URL=https://app.zoveto.com
# COS (when leads should hit your API, not SMTP-only):
#   COS_API_BASE_URL=https://<api-host>/api
#   WEB_CONTACT_SECRET=<match COS WEB_CONTACT_SECRET if enforced>
# Sentry (same DSN string in both):
#   NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest....sentry.io/...
#   SENTRY_DSN=https://...@....ingest....sentry.io/...
# Optional: NEXT_PUBLIC_SENTRY_ENVIRONMENT=preview  (Preview only)  |  SENTRY_ENVIRONMENT=production
# Source maps (Sentry Vercel integration OR CI): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
# Analytics (build-time): NEXT_PUBLIC_GA_MEASUREMENT_ID, optional PostHog / Clarity vars above
# Mail fallback: MAIL_FROM + SMTP_* when COS is down or not configured
