# Minimal local overlay — copy to `.env.local` (gitignored).
# Full reference + Vercel checklist: `.env.example`

NEXT_PUBLIC_SITE_URL=http://localhost:3002
NEXT_PUBLIC_COS_API_URL=http://127.0.0.1:4000/api
NEXT_PUBLIC_COS_APP_URL=http://localhost:5173
COS_API_BASE_URL=http://127.0.0.1:4000/api

# Optional tracking (build-time; production values live on Vercel)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_PROJECT_ID=
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (local optional — same DSN for both when testing)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# One-shot Sentry smoke test only (remove after verifying Issues)
# NEXT_PUBLIC_SENTRY_VERIFICATION=1
# SENTRY_VERIFY_SECRET=

# Monitors: ping http://localhost:3002/api/v1/health in staging/prod — no env required
