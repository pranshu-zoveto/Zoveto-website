{
  "name": "zoveto-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node scripts/run-dev.cjs",
    "dev:reset": "node scripts/clean-next.cjs && node scripts/run-dev.cjs",
    "dev:next": "node --require ./scripts/patch-readlink.cjs ./node_modules/next/dist/bin/next dev --webpack -p 3002",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "clean:next": "node scripts/clean-next.cjs",
    "build": "node --require ./scripts/patch-readlink.cjs ./node_modules/next/dist/bin/next build --webpack",
    "start": "node --require ./scripts/patch-readlink.cjs ./node_modules/next/dist/bin/next start -p 3000",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --ext .js,.jsx,.ts,.tsx",
    "test": "node --import tsx --test ./components/sections/dashboard/moduleData.test.ts ./components/sections/system-modules/stripModules.test.ts ./lib/dashboard-scroll-math.test.ts ./lib/home-lcp-performance.test.ts ./lib/module-nav.test.ts ./lib/marketing-bands.test.ts ./lib/pricing-plans.test.ts ./lib/pricing-page-faq.test.ts ./lib/compare-pages.test.ts ./lib/metadata-quality.test.ts ./lib/launch-readiness.test.ts ./lib/rate-limit.test.ts ./lib/team.test.ts ./lib/cookieConsent.test.ts ./lib/cos-forward.test.ts ./lib/lead-intake-mail.test.ts ./lib/http-json.test.ts ./lib/seo-landings.test.ts ./lib/blog-posts.test.ts ./lib/sitemap.test.ts ./lib/operational-proof.test.ts ./lib/features-section-closing-copy.test.ts ./lib/global-marketing-copy.test.ts ./lib/resolve-slug-params.test.ts ./lib/seo-enterprise-readiness.test.ts ./lib/content-scale-readiness.test.ts ./lib/early-access.test.ts ./lib/whatsapp-float.test.ts ./lib/industries.test.ts ./lib/phase1-case-rock-tear.test.ts ./lib/faq-hub.test.ts",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "check:cycles": "npx --yes madge@8 --circular --extensions ts,tsx .",
    "clean": "node scripts/clean-node-modules.cjs",
    "reinstall": "npm run clean && npm install",
    "generate-brand-pngs": "node scripts/generate-brand-pngs.cjs",
    "screenshot:mobile": "node scripts/mobile-screenshots.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/nextjs": "10.51.0",
    "@sentry/react": "10.51.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "countup.js": "^2.10.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "posthog-js": "^1.372.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.73.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.21",
    "@types/node": "20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18",
    "@types/three": "^0.184.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.12",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "glob": "^10.5.0",
    "postcss": "^8.5.12"
  }
}
